# Copia questo file in .env e compila i valori.
# Nessuno di questi valori è un segreto lato client: la anon key è pubblica
# per progettazione, la sicurezza è garantita dalle policy RLS nel database
# (vedi supabase/migrations). Non committare MAI la service_role key o le
# chiavi VAPID private: quelle vivono solo nei secrets delle Edge Functions.

VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Chiave pubblica VAPID, usata dal browser per la sottoscrizione Web Push.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
