# Secrets delle Edge Function (mai committare il file .env reale: solo
# questo .env.example). Si impostano con:
#   npx supabase secrets set --env-file supabase/functions/.env
#
# Generare una coppia di chiavi VAPID (una volta sola per progetto):
#   npx web-push generate-vapid-keys
# La chiave pubblica va anche in .env come VITE_VAPID_PUBLIC_KEY (client),
# quella privata resta SOLO qui.

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=mailto:tuoindirizzo@esempio.it

# SUPABASE_URL, SUPABASE_ANON_KEY e SUPABASE_SERVICE_ROLE_KEY sono già
# iniettate automaticamente da Supabase in ogni Edge Function: non vanno
# impostate qui.
